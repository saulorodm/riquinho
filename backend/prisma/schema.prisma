generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentMethod {
  PIX
  DEBIT_CARD
  CREDIT_CARD_FULL
  CREDIT_CARD_INSTALLMENTS
}

enum ExpenseKind {
  OPERATIONAL
  EXTRAORDINARY
  PATRIMONIAL
}

enum CategoryType {
  EXPENSE
  INCOME
  INVESTMENT
}

enum InvestmentType {
  STOCKS_ETFS
  REITS_FIIS
  FIXED_INCOME
  CASH_RESERVE
  CRYPTO
  OTHER
}

enum AssetCategory {
  VEHICLE
  RESIDENCE
  INCOME_PROPERTY
  LAND
  BUSINESS_EQUITY
  FGTS
  OTHER
}

model User {
  id              String               @id @default(cuid())
  name            String
  email           String               @unique
  passwordHash    String?
  cycleStartDay   Int?
  cycleEndDay     Int?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  financialCycles FinancialCycle[]
  categories      Category[]
  expenses        Expense[]
  incomes         Income[]
  investments     Investment[]
  assets          Asset[]
  loans           Loan[]
}

model FinancialCycle {
  id                 String               @id @default(cuid())
  userId             String
  name               String
  referenceLabel     String?
  startDate          DateTime
  endDate            DateTime
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses           Expense[]
  expenseInstallments ExpenseInstallment[]
  incomes            Income[]

  @@unique([userId, startDate, endDate])
  @@index([userId, startDate, endDate])
}

model Category {
  id              String       @id @default(cuid())
  userId          String
  name            String
  type            CategoryType
  budgetCeiling   Decimal?     @db.Decimal(10, 2)
  color           String?
  icon            String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses        Expense[]
  incomes         Income[]
  investments     Investment[]

  @@unique([userId, name, type])
}

model Expense {
  id                String               @id @default(cuid())
  userId            String
  financialCycleId  String?
  categoryId        String?
  expenseKind       ExpenseKind          @default(OPERATIONAL)
  isRecurring       Boolean              @default(false)
  title             String
  description       String?
  amount            Decimal              @db.Decimal(10, 2)
  purchaseDate      DateTime
  paymentMethod     PaymentMethod
  notes             String?
  installmentsCount Int                  @default(1)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  financialCycle    FinancialCycle?      @relation(fields: [financialCycleId], references: [id], onDelete: SetNull)
  category          Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  installments      ExpenseInstallment[]

  @@index([userId, purchaseDate])
}

model ExpenseInstallment {
  id                String          @id @default(cuid())
  expenseId         String
  financialCycleId  String?
  installmentNumber Int
  amount            Decimal         @db.Decimal(10, 2)
  dueDate           DateTime
  createdAt         DateTime        @default(now())
  expense           Expense         @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  financialCycle    FinancialCycle? @relation(fields: [financialCycleId], references: [id], onDelete: SetNull)

  @@unique([expenseId, installmentNumber])
  @@index([dueDate])
}

model Income {
  id               String          @id @default(cuid())
  userId           String
  financialCycleId String?
  categoryId       String?
  sourceName       String
  amount           Decimal         @db.Decimal(10, 2)
  receivedAt       DateTime
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  financialCycle   FinancialCycle? @relation(fields: [financialCycleId], references: [id], onDelete: SetNull)
  category         Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, receivedAt])
}

model Investment {
  id               String               @id @default(cuid())
  userId           String
  categoryId       String?
  name             String
  assetType        InvestmentType
  amountInvested   Decimal              @db.Decimal(10, 2)
  quantity         Decimal?             @db.Decimal(16, 4)
  currentQuantity  Decimal?             @db.Decimal(16, 4)
  averageUnitPrice Decimal?             @db.Decimal(12, 4)
  currentValue     Decimal?             @db.Decimal(10, 2)
  netCurrentValue  Decimal?             @db.Decimal(10, 2)
  investedAt       DateTime
  notes            String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  category         Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  snapshots        InvestmentSnapshot[]

  @@index([userId, investedAt])
  @@unique([userId, name, assetType])
}

model InvestmentSnapshot {
  id           String     @id @default(cuid())
  investmentId String
  value        Decimal    @db.Decimal(10, 2)
  capturedAt   DateTime
  investment   Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)

  @@index([capturedAt])
}

model Asset {
  id               String        @id @default(cuid())
  userId           String
  name             String
  category         AssetCategory
  acquisitionValue Decimal?      @db.Decimal(10, 2)
  currentValue     Decimal       @db.Decimal(10, 2)
  acquiredAt       DateTime
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, acquiredAt])
}

model Loan {
  id                String            @id @default(cuid())
  userId            String
  borrowerName      String
  principalAmount   Decimal           @db.Decimal(10, 2)
  installmentAmount Decimal           @db.Decimal(10, 2)
  dueDay            Int
  installmentsCount Int
  startDate         DateTime
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  installments      LoanInstallment[]

  @@index([userId, startDate])
}

model LoanInstallment {
  id                String    @id @default(cuid())
  loanId            String
  installmentNumber Int
  amount            Decimal   @db.Decimal(10, 2)
  dueDate           DateTime
  paidAt            DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  loan              Loan      @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@unique([loanId, installmentNumber])
  @@index([dueDate])
}
